% language in the top right corner.

\newcommand*{\ollicensetext}[3]
  {\textit{#1}
  by
  #2
  is licensed under a 
  #3.}
\newcommand*{\olshortlicensetext}[1]
  {\textit{\href{\OLTlinkname}{\jobname}}
  \ifgitinfo\ 
  by #1 /
  \href{http://creativecommons.org/licenses/by/4.0/}{CC--BY}.}
\newcommand*{\oluselicensetext}
